# Scoop Theory — Environment Variables
# Copy this to .env and fill in your values

# ── API Backend URL ──────────────────────────────────────────────────────────
# During local development (localhost), leave blank — the app uses /api
# For production on Hostinger, set this to your full API URL:
# VITE_API_URL=https://scoop-theory.com/api
# Or if using the Hostinger default subdomain:
# VITE_API_URL=https://gray-gerbil-641296.hostingersite.com/api
VITE_API_URL=